# Forcer CRLF sur les fichiers Windows (sinon cmd.exe casse)
*.bat   text eol=crlf
*.cmd   text eol=crlf
*.ps1   text eol=crlf

# LF natif partout ailleurs (Python, LaTeX, configs textuelles)
*.py    text eol=lf
*.tex   text eol=lf
*.sty   text eol=lf
*.md    text eol=lf
*.cfg   text eol=lf
*.spec  text eol=lf
*.iss   text eol=crlf

# Binaires : pas de conversion
*.png   binary
*.pdf   binary
*.exe   binary
*.dat   binary
